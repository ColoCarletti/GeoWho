{
  "name": "geowho",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "data:fetch": "node scripts/fetch-people.mjs && node scripts/fetch-people-extra.mjs && node scripts/fetch-people-must.mjs && node scripts/fetch-dates.mjs && node scripts/fetch-occupations.mjs",
    "data:prep": "node scripts/prep-people.mjs",
    "data": "npm run data:fetch && npm run data:prep",
    "verify:logic": "tsx scripts/verify-logic.ts",
    "verify:render": "tsx --tsconfig tsconfig.app.json scripts/verify-render.tsx",
    "verify": "npm run verify:logic && npm run verify:render"
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/d3-geo": "^3.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.5.4",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "postcss": "^8.5.20",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.23.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "world-countries": "^5.1.0"
  }
}
